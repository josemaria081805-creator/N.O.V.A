<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>N.O.V.A. — Asistente</title>
<style>
  :root{
    --bg: #060a12;
    --bg2: #0b111d;
    --cyan: #4fd6ff;
    --cyan-dim: #1c5c73;
    --amber: #ffb454;
    --text: #d9ecf5;
    --text-dim: #6f8a9c;
    --danger: #ff5c5c;
    --panel-border: rgba(79,214,255,0.25);
  }
  *{ box-sizing:border-box; }
  html,body{
    margin:0; padding:0; height:100%;
    background: radial-gradient(circle at 50% 20%, var(--bg2), var(--bg) 70%);
    color: var(--text);
    font-family: 'Segoe UI', system-ui, sans-serif;
    overflow:hidden;
  }
  .scan{
    position:fixed; inset:0; pointer-events:none;
    background: repeating-linear-gradient(0deg, rgba(79,214,255,0.02) 0px, rgba(79,214,255,0.02) 1px, transparent 1px, transparent 3px);
    z-index:5;
  }
  .app{
    position:relative; width:100%; height:100vh;
    display:flex; flex-direction:column; align-items:center;
    padding: 18px 18px 12px;
  }
  header{
    width:100%; max-width:920px;
    display:flex; justify-content:space-between; align-items:baseline;
    border-bottom:1px solid var(--panel-border);
    padding-bottom:10px; margin-bottom:6px;
  }
  header .brand{
    font-family: 'Consolas', monospace;
    letter-spacing:6px; font-size:15px; color:var(--cyan);
    text-shadow:0 0 12px rgba(79,214,255,0.6);
  }
  header .clock{
    font-family:'Consolas', monospace; color:var(--text-dim); font-size:12px; letter-spacing:1px;
  }

  .core-wrap{ position:relative; width:220px; height:220px; margin: 6px 0 4px; flex-shrink:0; }
  .core-wrap svg{ width:100%; height:100%; }
  .ring{ fill:none; stroke:var(--cyan-dim); stroke-width:1.2; }
  .ring-active{ fill:none; stroke:var(--cyan); stroke-width:2; filter:drop-shadow(0 0 6px var(--cyan)); }
  .ring1{ animation: spin 12s linear infinite; }
  .ring2{ animation: spin 18s linear infinite reverse; }
  .ring3{ animation: spin 26s linear infinite; }
  @keyframes spin{ from{ transform:rotate(0deg);} to{ transform:rotate(360deg);} }
  .core-center{
    position:absolute; inset:0; display:flex; align-items:center; justify-content:center;
  }
  .core-dot{
    width:46px; height:46px; border-radius:50%;
    background: radial-gradient(circle, #bdf3ff 0%, var(--cyan) 45%, #063142 100%);
    box-shadow: 0 0 30px 6px rgba(79,214,255,0.55);
    transition: all .25s ease;
  }
  .core-wrap.listening .core-dot{
    background: radial-gradient(circle, #fff 0%, var(--amber) 45%, #5a3200 100%);
    box-shadow: 0 0 40px 10px rgba(255,180,84,0.65);
    animation: pulse 1s ease-in-out infinite;
  }
  .core-wrap.speaking .ring-active{ animation-duration: 4s, 6s, 9s; }
  .core-wrap.speaking .core-dot{
    animation: pulse .6s ease-in-out infinite;
  }
  @keyframes pulse{ 0%,100%{ transform:scale(1);} 50%{ transform:scale(1.18);} }

  .status{
    font-family:'Consolas', monospace; font-size:12px; letter-spacing:3px;
    color: var(--cyan); text-transform:uppercase; margin-bottom:10px; min-height:16px;
    text-shadow:0 0 8px rgba(79,214,255,0.5);
  }

  .console{
    width:100%; max-width:920px; flex:1; min-height:0;
    display:flex; flex-direction:column;
    border:1px solid var(--panel-border); border-radius:6px;
    background: rgba(6,12,20,0.6); backdrop-filter: blur(2px);
    overflow:hidden;
  }
  .log{
    flex:1; overflow-y:auto; padding:14px 18px; font-size:14px; line-height:1.5;
  }
  .log::-webkit-scrollbar{ width:6px; }
  .log::-webkit-scrollbar-thumb{ background:var(--cyan-dim); border-radius:3px; }
  .msg{ margin-bottom:14px; max-width:82%; }
  .msg .who{
    font-family:'Consolas', monospace; font-size:10px; letter-spacing:2px;
    text-transform:uppercase; margin-bottom:3px;
  }
  .msg.user{ margin-left:auto; text-align:right; }
  .msg.user .who{ color: var(--amber); }
  .msg.user .bubble{ background: rgba(255,180,84,0.08); border:1px solid rgba(255,180,84,0.3); border-radius:10px 10px 2px 10px; }
  .msg.ai .who{ color: var(--cyan); }
  .msg.ai .bubble{ background: rgba(79,214,255,0.06); border:1px solid var(--panel-border); border-radius:10px 10px 10px 2px; }
  .bubble{ padding:9px 13px; display:inline-block; }
  .msg.sys{ text-align:center; }
  .msg.sys .bubble{ background:none; border:none; color:var(--text-dim); font-size:12px; font-style:italic; }

  .inputbar{
    display:flex; align-items:center; gap:8px;
    border-top:1px solid var(--panel-border);
    padding:10px 12px;
  }
  .inputbar input{
    flex:1; background:transparent; border:1px solid var(--panel-border); border-radius:20px;
    padding:10px 16px; color:var(--text); font-size:14px; outline:none;
  }
  .inputbar input:focus{ border-color:var(--cyan); box-shadow:0 0 8px rgba(79,214,255,0.3); }
  .btn{
    width:40px; height:40px; border-radius:50%; border:1px solid var(--panel-border);
    background:transparent; color:var(--cyan); cursor:pointer; font-size:16px;
    display:flex; align-items:center; justify-content:center; flex-shrink:0;
    transition: all .15s ease;
  }
  .btn:hover{ background:rgba(79,214,255,0.1); box-shadow:0 0 10px rgba(79,214,255,0.4); }
  .btn.mic.on{ background:var(--amber); border-color:var(--amber); color:#1a0f00; box-shadow:0 0 14px rgba(255,180,84,0.6); }
  .btn.mute{ color:var(--text-dim); }
  .btn.mute.off{ color:var(--danger); border-color:var(--danger); }
  .btn:disabled{ opacity:.35; cursor:not-allowed; }

  footer{ font-family:'Consolas', monospace; font-size:10px; color:var(--text-dim); letter-spacing:1px; margin-top:8px; }
</style>
</head>
<body>
<div class="scan"></div>
<div class="app">
  <header>
    <div class="brand">N.O.V.A.</div>
    <div class="clock" id="clock">--:--:--</div>
  </header>

  <div class="core-wrap" id="coreWrap">
    <svg viewBox="0 0 220 220">
      <circle class="ring ring1" cx="110" cy="110" r="95"/>
      <circle class="ring-active ring1" cx="110" cy="110" r="95" stroke-dasharray="40 550"/>
      <circle class="ring ring2" cx="110" cy="110" r="75"/>
      <circle class="ring-active ring2" cx="110" cy="110" r="75" stroke-dasharray="30 440"/>
      <circle class="ring ring3" cx="110" cy="110" r="55"/>
      <circle class="ring-active ring3" cx="110" cy="110" r="55" stroke-dasharray="20 320"/>
    </svg>
    <div class="core-center"><div class="core-dot"></div></div>
  </div>

  <div class="status" id="statusLabel">SISTEMA EN ESPERA</div>

  <div class="console">
    <div class="log" id="log"></div>
    <div class="inputbar">
      <button class="btn mic" id="micBtn" title="Hablar">🎙</button>
      <input id="textInput" type="text" placeholder="Escribe una orden o pregunta..." autocomplete="off">
      <button class="btn" id="sendBtn" title="Enviar">➤</button>
      <button class="btn mute" id="muteBtn" title="Silenciar voz">🔊</button>
    </div>
  </div>
  <footer>NOVA v1.0 · asistente conversacional · powered by Claude</footer>
</div>

<script>
const log = document.getElementById('log');
const statusLabel = document.getElementById('statusLabel');
const coreWrap = document.getElementById('coreWrap');
const micBtn = document.getElementById('micBtn');
const sendBtn = document.getElementById('sendBtn');
const muteBtn = document.getElementById('muteBtn');
const textInput = document.getElementById('textInput');
const clockEl = document.getElementById('clock');

let history = [];
let voiceMuted = false;
let isBusy = false;

function tickClock(){
  const now = new Date();
  clockEl.textContent = now.toLocaleTimeString('es-CO', {hour12:false});
}
setInterval(tickClock, 1000); tickClock();

function addMessage(who, text){
  const div = document.createElement('div');
  div.className = 'msg ' + who;
  const label = who === 'user' ? 'Tú' : (who === 'ai' ? 'NOVA' : '');
  div.innerHTML = `${label ? `<div class="who">${label}</div>` : ''}<div class="bubble"></div>`;
  div.querySelector('.bubble').textContent = text;
  log.appendChild(div);
  log.scrollTop = log.scrollHeight;
  return div;
}

function setStatus(text, mode){
  statusLabel.textContent = text;
  coreWrap.classList.remove('listening','speaking');
  if(mode) coreWrap.classList.add(mode);
}

addMessage('sys', 'Núcleo inicializado. Escribe o pulsa el micrófono para hablar conmigo.');

// ---- Speech recognition (input) ----
let recognition = null;
let recognizing = false;
const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
if (SpeechRecognition) {
  recognition = new SpeechRecognition();
  recognition.lang = 'es-CO';
  recognition.interimResults = false;
  recognition.maxAlternatives = 1;

  recognition.onstart = () => {
    recognizing = true;
    micBtn.classList.add('on');
    setStatus('ESCUCHANDO...', 'listening');
  };
  recognition.onerror = () => {
    recognizing = false;
    micBtn.classList.remove('on');
    setStatus('SISTEMA EN ESPERA');
  };
  recognition.onend = () => {
    recognizing = false;
    micBtn.classList.remove('on');
    if(!isBusy) setStatus('SISTEMA EN ESPERA');
  };
  recognition.onresult = (event) => {
    const said = event.results[0][0].transcript;
    textInput.value = said;
    sendMessage(said);
  };
} else {
  micBtn.disabled = true;
  micBtn.title = 'Reconocimiento de voz no disponible en este navegador';
}

micBtn.addEventListener('click', () => {
  if (!recognition) return;
  if (recognizing) { recognition.stop(); return; }
  try { recognition.start(); } catch(e) {}
});

// ---- Speech synthesis (output) ----
function speak(text){
  if (voiceMuted) return;
  if (!('speechSynthesis' in window)) return;
  window.speechSynthesis.cancel();
  const utter = new SpeechSynthesisUtterance(text);
  utter.lang = 'es-ES';
  utter.rate = 1.02;
  utter.pitch = 0.95;
  const voices = window.speechSynthesis.getVoices();
  const esVoice = voices.find(v => v.lang && v.lang.startsWith('es'));
  if (esVoice) utter.voice = esVoice;
  utter.onstart = () => setStatus('RESPONDIENDO...', 'speaking');
  utter.onend = () => setStatus('SISTEMA EN ESPERA');
  window.speechSynthesis.speak(utter);
}
// warm up voices list (some browsers load async)
if ('speechSynthesis' in window) { window.speechSynthesis.getVoices(); }

muteBtn.addEventListener('click', () => {
  voiceMuted = !voiceMuted;
  muteBtn.classList.toggle('off', voiceMuted);
  muteBtn.textContent = voiceMuted ? '🔇' : '🔊';
  if (voiceMuted) window.speechSynthesis.cancel();
});

// ---- Sending messages to Claude ----
const SYSTEM_PROMPT = `Eres NOVA, un asistente de inteligencia artificial personal al estilo Jarvis: eficiente, cercano, con un toque de personalidad ingeniosa pero siempre útil y respetuoso. Respondes SIEMPRE en español, con lenguaje sencillo y claro, sin tecnicismos innecesarios, en frases cortas (esto es clave porque tus respuestas también se leen en voz alta). Evita el markdown (nada de asteriscos, numerales ni tablas), responde en texto plano fluido. Si no sabes algo con certeza, dilo con honestidad. Sé breve salvo que el usuario pida más detalle.`;

async function sendMessage(text){
  const trimmed = text.trim();
  if (!trimmed || isBusy) return;
  addMessage('user', trimmed);
  textInput.value = '';
  history.push({ role: 'user', content: trimmed });
  isBusy = true;
  sendBtn.disabled = true;
  setStatus('PROCESANDO...', 'speaking');

  try {
    const response = await fetch("https://api.anthropic.com/v1/messages", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        model: "claude-sonnet-4-6",
        max_tokens: 1000,
        system: SYSTEM_PROMPT,
        messages: history
      })
    });
    const data = await response.json();
    let replyText = "No pude procesar eso. Intenta de nuevo.";
    if (data && data.content) {
      replyText = data.content.map(b => b.type === 'text' ? b.text : '').join(' ').trim() || replyText;
    }
    history.push({ role: 'assistant', content: replyText });
    addMessage('ai', replyText);
    speak(replyText);
  } catch (err) {
    addMessage('sys', 'Error de conexión con el núcleo. Verifica tu red.');
    setStatus('SISTEMA EN ESPERA');
  } finally {
    isBusy = false;
    sendBtn.disabled = false;
    if (voiceMuted) setStatus('SISTEMA EN ESPERA');
  }
}

sendBtn.addEventListener('click', () => sendMessage(textInput.value));
textInput.addEventListener('keydown', (e) => {
  if (e.key === 'Enter') sendMessage(textInput.value);
});
</script>
</body>
</html>
